{
  "name": "@dlyzzt/pi-desktop",
  "version": "0.1.1",
  "description": "Pi Agent Desktop — pure Electron desktop app for the pi coding agent",
  "homepage": "https://github.com/DLYZZT/pi-desktop#readme",
  "license": "Apache-2.0",
  "productName": "Pi Agent Desktop",
  "author": "DLYZZT",
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "out/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "build:main": "tsup --config tsup.config.ts",
    "build:renderer": "vite build",
    "build:smoke": "tsup --config tsup.smoke.config.ts",
    "lint": "eslint src scripts *.ts *.mjs --max-warnings=0",
    "lint:fix": "eslint src scripts *.ts *.mjs --fix --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "node scripts/test.mjs",
    "check:contract": "node scripts/check-contract-coverage.mjs",
    "check:desktop-security": "node scripts/check-desktop-security.mjs",
    "check:production-artifacts": "node scripts/check-production-artifacts.mjs",
    "smoke": "node scripts/smoke-electron.mjs",
    "verify": "node scripts/verify.mjs",
    "prepare": "husky",
    "start": "electron .",
    "pack": "npm run verify && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "npm run verify && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never",
    "dist:mac:signed": "node scripts/build-mac-release.mjs",
    "dist:mac:notarized": "node scripts/build-mac-release.mjs --notarize"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@larksuiteoapi/node-sdk": "^1.71.1",
    "@lobehub/icons": "^5.6.0",
    "@rc-component/qrcode": "^2.0.0",
    "electron-updater": "6.8.9",
    "katex": "^0.16.47",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "silk-wasm": "^3.7.1"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "43.1.1",
    "electron-builder": "26.0.12",
    "esbuild": "^0.27.7",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.2.2",
    "tsup": "8.5.1",
    "typescript": "^5",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.3.5"
  }
}
