{
  "name": "@dlyzzt/pi-desktop",
  "version": "0.1.0",
  "description": "Pi Agent Desktop \u2014 pure Electron desktop app for the pi coding agent",
  "homepage": "https://github.com/DLYZZT/pi-desktop#readme",
  "license": "MIT",
  "productName": "Pi Agent Desktop",
  "author": "DLYZZT",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "build:main": "tsup --config tsup.config.ts",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "node --test src/shared/*.test.mjs",
    "check:contract": "node scripts/check-contract-coverage.mjs",
    "smoke": "node scripts/smoke-electron.mjs",
    "verify": "node scripts/verify.mjs",
    "start": "electron .",
    "pack": "npm run verify && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "npm run verify && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never",
    "engines-note": "Use Node 20+ for dev; Electron ships its own runtime"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@lobehub/icons": "^5.6.0",
    "katex": "^0.16.47",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "35.7.5",
    "electron-builder": "26.0.12",
    "electron-updater": "^6.6.2",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "tsup": "8.5.1",
    "typescript": "^5",
    "vite": "^6.3.5"
  }
}
