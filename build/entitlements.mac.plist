<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Draft entitlements for PR4. Expand only if notarization / hardened runtime requires it (PR8).
  Prefer signing official Node + native .node addons over broad library-validation disable.
-->
<plist version="1.0">
<dict>
  <!-- Outbound HTTPS for model APIs, skill registry, auto-update -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Local Next server binds 127.0.0.1 -->
  <key>com.apple.security.network.server</key>
  <true/>
  <!--
  Uncomment only if notarization fails loading unsigned native modules:
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  Uncomment only if official Node requires executable memory / JIT under HR:
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  -->
</dict>
</plist>
